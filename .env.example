# Copy to .env and fill in. docker-compose.yml reads this file automatically.

# Optional: only needed if you authenticate with an API key instead of
# interactive OAuth login (`claude` then /login).
ANTHROPIC_API_KEY=

# Git identity used for commits inside the sandbox.
# Take these over from your host with:
#   git config --global user.name   -> GIT_USER_NAME
#   git config --global user.email  -> GIT_USER_EMAIL
GIT_USER_NAME=
GIT_USER_EMAIL=

# Which directory to hand to the sandbox, and the profile that configures it
# (skills / plugins / MCP servers). Pair them: one profile per workspace.
# See profiles/README.md.
WORKSPACE_DIR=./workspace
CLAUDE_PROFILE=default

# Secrets referenced as ${VAR} from a profile's mcp.json. Keep them here rather
# than in mcp.json itself, and add a passthrough in docker-compose.yml's
# environment: block for any you add.
GRAFANA_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=
